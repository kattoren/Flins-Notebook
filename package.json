{
  "name": "flins-notes",
  "version": "0.1.0",
  "description": "Windows desktop reminder app with desktop pet",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.flins.notes",
    "productName": "Flins Notes",
    "author": "Kattoren",
    "icon": "assets/flins/flins_idle.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "data/.gitkeep",
      "package.json"
    ],
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
