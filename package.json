{
  "name": "flins-notes",
  "version": "0.1.0",
  "description": "Windows desktop reminder app with desktop pet",
  "author": "Kattoren",
  "main": "src/main.js",
  "scripts": {
    "start": "electron-forge start",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "build": {
    "appId": "com.flins.notes",
    "productName": "Flins Notes",
    "icon": "assets/flins/flins_idle.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "data/.gitkeep",
      "package.json"
    ],
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^35.0.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
